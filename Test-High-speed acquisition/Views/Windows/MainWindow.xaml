<Window x:Class="Test_High_speed_acquisition.Views.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Test_High_speed_acquisition.Views.Windows"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="高速采集串口工具" Height="560" Width="920" WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">
    <Grid Margin="16" Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="串口高速采集"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="#F3F3F3"
                   Margin="4,0,0,12" />

        <Border Grid.Row="1"
                Padding="16"
                Margin="0,0,0,12"
                CornerRadius="10"
                BorderBrush="#3A3A3A"
                BorderThickness="1"
                Background="#2A2A2A">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="串口" Margin="0,0,0,6" FontWeight="Medium" Foreground="#F3F3F3" />
                <TextBlock Grid.Row="0" Grid.Column="1" Text="波特率" Margin="12,0,0,6" FontWeight="Medium" Foreground="#F3F3F3" />

                <ComboBox Grid.Row="1"
                          Grid.Column="0"
                          MinWidth="220"
                          Margin="0,0,12,0"
                          ItemsSource="{Binding AvailablePorts}"
                          SelectedItem="{Binding SelectedPort}" />

                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Margin="0,0,12,0"
                         VerticalContentAlignment="Center"
                         Text="{Binding BaudRate}" />

                <Button Grid.Row="1"
                        Grid.Column="2"
                        MinWidth="92"
                        Margin="0,0,8,0"
                        Command="{Binding RefreshPortsCommand}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ArrowSync24" Margin="0,0,6,0" />
                        <TextBlock Text="刷新" />
                    </StackPanel>
                </Button>

                <Button Grid.Row="1"
                        Grid.Column="3"
                        MinWidth="110"
                        Margin="0,0,8,0"
                        Command="{Binding OpenPortCommand}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="PlugConnected24" Margin="0,0,6,0" />
                        <TextBlock Text="打开串口" />
                    </StackPanel>
                </Button>

                <Button Grid.Row="1"
                        Grid.Column="4"
                        MinWidth="110"
                        Margin="0,0,8,0"
                        Command="{Binding ClosePortCommand}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="PlugDisconnected24" Margin="0,0,6,0" />
                        <TextBlock Text="关闭串口" />
                    </StackPanel>
                </Button>

                <Button Grid.Row="1"
                        Grid.Column="5"
                        MinWidth="90"
                        Command="{Binding ClearReceivedDataCommand}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Eraser24" Margin="0,0,6,0" />
                        <TextBlock Text="清空" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Margin="0,0,0,8"
                    Padding="10,8"
                    CornerRadius="8"
                    BorderBrush="#3A3A3A"
                    BorderThickness="1"
                    Background="#252525">
                <TextBlock Text="{Binding StatusMessage}" Foreground="#F3F3F3" />
            </Border>

            <TextBox Grid.Row="1"
                     Padding="10"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas"
                     FontSize="13"
                     AcceptsReturn="True"
                     TextWrapping="NoWrap"
                     IsReadOnly="True"
                     Foreground="#F3F3F3"
                     Background="#141414"
                     BorderBrush="#3A3A3A"
                     Text="{Binding ReceivedData}" />
        </Grid>
    </Grid>
</Window>
