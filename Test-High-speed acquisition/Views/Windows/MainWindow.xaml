<Window x:Class="Test_High_speed_acquisition.Views.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Test_High_speed_acquisition.Views.Windows"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="高速采集串口工具" Height="620" Width="980" WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">
    <Grid Margin="16" Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="串口高速采集"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="#F3F3F3"
                   Margin="4,0,0,12" />

        <Border Grid.Row="1"
                Padding="16"
                Margin="0,0,0,12"
                CornerRadius="10"
                BorderBrush="#3A3A3A"
                BorderThickness="1"
                Background="#2A2A2A">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="130" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="串口" Margin="0,0,0,6" FontWeight="Medium" Foreground="#F3F3F3" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="波特率" Margin="12,0,0,6" FontWeight="Medium" Foreground="#F3F3F3" />
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="间隔(ms)" Margin="12,0,0,6" FontWeight="Medium" Foreground="#F3F3F3" />
                    <TextBlock Grid.Row="0" Grid.Column="3" Text="从站地址" Margin="12,0,0,6" FontWeight="Medium" Foreground="#F3F3F3" />

                    <ComboBox Grid.Row="1"
                              Grid.Column="0"
                              MinWidth="240"
                              Margin="0,0,12,0"
                              ItemsSource="{Binding AvailablePorts}"
                              SelectedItem="{Binding SelectedPort}" />

                    <TextBox Grid.Row="1"
                             Grid.Column="1"
                             Margin="0,0,12,0"
                             VerticalContentAlignment="Center"
                             Text="{Binding BaudRate}" />

                    <TextBox Grid.Row="1"
                             Grid.Column="2"
                             Margin="0,0,12,0"
                             VerticalContentAlignment="Center"
                             Text="{Binding PollIntervalMs}" />

                    <TextBox Grid.Row="1"
                             Grid.Column="3"
                             Margin="0,0,0,0"
                             VerticalContentAlignment="Center"
                             Text="{Binding SlaveId}" />

                    <Button Grid.Row="2"
                            Grid.Column="0"
                            MinWidth="92"
                            Margin="0,12,8,0"
                            HorizontalAlignment="Left"
                            Command="{Binding RefreshPortsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="ArrowSync24" Margin="0,0,6,0" />
                            <TextBlock Text="刷新" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Row="2"
                            Grid.Column="0"
                            MinWidth="110"
                            Margin="104,12,8,0"
                            HorizontalAlignment="Left"
                            Command="{Binding OpenPortCommand}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="PlugConnected24" Margin="0,0,6,0" />
                            <TextBlock Text="打开串口" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Row="2"
                            Grid.Column="0"
                            MinWidth="110"
                            Margin="222,12,8,0"
                            HorizontalAlignment="Left"
                            Command="{Binding ClosePortCommand}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="PlugDisconnected24" Margin="0,0,6,0" />
                            <TextBlock Text="关闭串口" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Row="2"
                            Grid.Column="0"
                            MinWidth="90"
                            Margin="340,12,0,0"
                            HorizontalAlignment="Left"
                            Command="{Binding ClearReceivedDataCommand}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Eraser24" Margin="0,0,6,0" />
                            <TextBlock Text="清空" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Row="2"
                            Grid.Column="0"
                            MinWidth="110"
                            Margin="438,12,8,0"
                            HorizontalAlignment="Left"
                            Command="{Binding StartAcquisitionCommand}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Play24" Margin="0,0,6,0" />
                            <TextBlock Text="开始发送" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Row="2"
                            Grid.Column="0"
                            MinWidth="110"
                            Margin="556,12,0,0"
                            HorizontalAlignment="Left"
                            Command="{Binding StopAcquisitionCommand}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Pause24" Margin="0,0,6,0" />
                            <TextBlock Text="停止发送" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Row="2"
                            Grid.Column="0"
                            MinWidth="110"
                            Margin="674,12,8,0"
                            HorizontalAlignment="Left"
                            Command="{Binding RestartPortCommand}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="ArrowSync24" Margin="0,0,6,0" />
                            <TextBlock Text="重启串口" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Row="2"
                            Grid.Column="0"
                            MinWidth="110"
                            Margin="792,12,0,0"
                            HorizontalAlignment="Left"
                            Command="{Binding RefreshHealthCommand}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Pulse24" Margin="0,0,6,0" />
                            <TextBlock Text="刷新诊断" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Row="2"
                            Grid.Column="0"
                            MinWidth="110"
                            Margin="910,12,0,0"
                            HorizontalAlignment="Left"
                            Command="{Binding ExportDiagnosticsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="ArrowDownload24" Margin="0,0,6,0" />
                            <TextBlock Text="导出诊断" />
                        </StackPanel>
                    </Button>
                </Grid>

                <Expander Grid.Row="1"
                          Margin="0,12,0,0"
                          Background="#2A2A2A"
                          Foreground="#F3F3F3"
                          IsExpanded="True"
                          Header="报文配置">
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="功能码" Margin="0,0,12,6" FontWeight="Medium" Foreground="#F3F3F3" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="起始地址" Margin="0,0,12,6" FontWeight="Medium" Foreground="#F3F3F3" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="寄存器长度" Margin="0,0,0,6" FontWeight="Medium" Foreground="#F3F3F3" />

                        <TextBox Grid.Row="1"
                                 Grid.Column="0"
                                 Margin="0,0,12,0"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding FunctionCode}" />

                        <TextBox Grid.Row="1"
                                 Grid.Column="1"
                                 Margin="0,0,12,0"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding StartAddress}" />

                        <TextBox Grid.Row="1"
                                 Grid.Column="2"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding RegisterCount}" />
                    </Grid>
                </Expander>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Margin="0,0,0,8"
                    Padding="10,8"
                    CornerRadius="8"
                    BorderBrush="#3A3A3A"
                    BorderThickness="1"
                    Background="#252525">
                <TextBlock Text="{Binding StatusMessage}" Foreground="#F3F3F3" />
            </Border>

            <Border Grid.Row="1"
                    Margin="0,0,0,8"
                    Padding="10,8"
                    CornerRadius="8"
                    BorderBrush="#3A3A3A"
                    BorderThickness="1"
                    Background="#20262B">
                <StackPanel>
                    <TextBlock Text="{Binding HealthSummary}" Foreground="#D6F5FF" />
                    <TextBlock Text="{Binding RecentDiagnostics}" Foreground="#FFCCAA" FontSize="11" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding LastDiagnosticExportPath}" Foreground="#8FB6C3" FontSize="11" />
                </StackPanel>
            </Border>

            <TextBox Grid.Row="2"
                     x:Name="ReceivedDataTextBox"
                     Padding="10"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas"
                     FontSize="13"
                     AcceptsReturn="True"
                     TextWrapping="NoWrap"
                     IsReadOnly="True"
                     IsUndoEnabled="False"
                     UndoLimit="0"
                     Foreground="#F3F3F3"
                     Background="#141414"
                     BorderBrush="#3A3A3A"
                     TextChanged="ReceivedDataTextBox_OnTextChanged"
                     Text="{Binding ReceivedData}" />
        </Grid>
    </Grid>
</Window>
