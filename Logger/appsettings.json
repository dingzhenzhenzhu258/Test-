{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff} {Level:u3}] {SourceContext}.{MemberName} (Line: {LineNumber})  消息： {Message:lj}{NewLine}{Exception}{NewLine}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs\\app.log",
          "rollingInterval": "Day",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff} {Level:u3}] 方法名： {SourceContext}.{MemberName} (Line: {LineNumber})  消息： {Message:lj}{NewLine}{Exception}{NewLine}",
          "retainedFileCountLimit": 7
        }
      }
    ],
    "Enrich": [ "WithThreadId", "FromLogContext" ]
  },
  "Logger": {
    "Otlp": {
      "Enabled": true,
      "ProbeOnStartup": true,
      "ProbeTimeoutMs": 200,
      "AutoRecoverProbe": true,
      "AutoRecoverProbeIntervalMs": 30000,
      "AutoRecoverApplyForLogs": true,
      "AutoRecoverApplyForTelemetry": true,
      "AutoRecoverApplyForTelemetryRuntimeSwitch": false,
      "ReplayQueueEnabled": true,
      "ReplayBatchSize": 200,
      "ReplayQueueMaxFileSizeMb": 50,
      "ReplayQueueMaxTotalSizeMb": 500,
      "ReplayQueueMaxAgeHours": 72,
      "ReplayQueueOverflowStrategy": "DropOldest",
      "LogsEndpoint": "http://localhost:5080/api/default/v1/logs",
      "TracesEndpoint": "http://localhost:5080/api/default/v1/traces",
      "MetricsEndpoint": "http://localhost:5080/api/default/v1/metrics"
    }
  },
  "SerialPortService": {
    "GenericHandler": {
      "ResponseChannelCapacity": 4096,
      "SampleLogInterval": 200,
      "DropWhenNoActiveRequest": true,
      "ResponseChannelFullMode": "Wait",
      "WaitModeQueueCapacity": 8192,
      "WaitBacklogAlertThreshold": 2048
    },
    "Reconnect": {
      "IntervalMs": 1000,
      "MaxAttempts": 3
    }
  }
}
